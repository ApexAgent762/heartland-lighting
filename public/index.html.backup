<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Heartland Permanent Lighting</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root{--green:#1D9E75;--green-light:#EAF3DE;--green-dark:#085041;--gold:#BA7517;--gold-light:#FAEEDA;--gold-dark:#633806;--purple:#534AB7;--purple-light:#EEEDFE;--bg:#F8F7F4;--card:#FFFFFF;--border:rgba(0,0,0,0.08);--text:#1a1a1a;--muted:#888;--radius:14px;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.hidden{display:none!important;}
#login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;}
.login-card{background:var(--card);border-radius:20px;padding:2.5rem 2rem;width:100%;max-width:380px;border:1px solid var(--border);}
.login-logo{font-family:'DM Serif Display',serif;font-size:22px;color:var(--green-dark);margin-bottom:4px;}
.login-sub{font-size:13px;color:var(--muted);margin-bottom:2rem;}
.field{margin-bottom:1rem;}
.field label{display:block;font-size:12px;font-weight:500;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em;}
.field input{width:100%;padding:12px 14px;border-radius:10px;border:1px solid var(--border);font-size:15px;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);outline:none;}
.field input:focus{border-color:var(--green);}
.login-btn{width:100%;padding:13px;border-radius:10px;background:var(--green-dark);color:#fff;border:none;font-size:15px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;}
.login-btn:hover{background:var(--green);}
.login-err{font-size:13px;color:#E24B4A;margin-top:10px;text-align:center;}
#app{display:none;min-height:100vh;}
.topbar{background:var(--card);border-bottom:1px solid var(--border);padding:0 1.25rem;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:10;}
.topbar-logo{font-family:'DM Serif Display',serif;font-size:17px;color:var(--green-dark);}
.topbar-user{font-size:13px;color:var(--muted);}
.logout-btn{font-size:13px;color:var(--muted);background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:6px;}
.logout-btn:hover{background:var(--bg);}
.tabs-wrap{background:var(--card);border-bottom:1px solid var(--border);padding:0 1.25rem;overflow-x:auto;white-space:nowrap;}
.tabs-wrap::-webkit-scrollbar{display:none;}
.tab-btn{display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:var(--muted);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;font-family:'DM Sans',sans-serif;}
.tab-btn.active{color:var(--green-dark);border-bottom-color:var(--green-dark);}
.content{padding:1.25rem;max-width:780px;margin:0 auto;}
.view{display:none;}
.view.active{display:block;}
.card{background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:1.25rem;margin-bottom:1rem;}
.section-label{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px;}
.avatar{border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;flex-shrink:0;}
.earned-hero{background:var(--green-light);border-radius:var(--radius);padding:1.5rem;text-align:center;margin-bottom:1rem;}
.earned-label{font-size:13px;font-weight:500;color:var(--green);margin-bottom:6px;}
.earned-amount{font-family:'DM Serif Display',serif;font-size:52px;color:var(--green-dark);line-height:1;}
.earned-sub{font-size:13px;color:var(--green);margin-top:8px;}
.metrics{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:1rem;}
.metric{background:var(--bg);border-radius:10px;padding:.875rem 1rem;}
.metric-label{font-size:11px;color:var(--muted);margin-bottom:4px;font-weight:500;}
.metric-value{font-size:22px;font-weight:600;color:var(--text);}
.metric-3{grid-template-columns:repeat(3,1fr);}
.owner-hero{background:var(--green-light);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:1rem;display:flex;align-items:center;justify-content:space-between;}
.owner-hero-amount{font-family:'DM Serif Display',serif;font-size:36px;color:var(--green-dark);}
.emp-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);}
.emp-item:last-child{border-bottom:none;}
.emp-name{font-size:14px;font-weight:500;}
.emp-sub{font-size:12px;color:var(--muted);}
.emp-earned-amount{font-size:16px;font-weight:600;color:var(--green-dark);}
.emp-earned-rev{font-size:11px;color:var(--muted);}
.prog-track{height:8px;background:var(--bg);border-radius:99px;overflow:hidden;margin:6px 0;}
.prog-fill{height:100%;border-radius:99px;background:var(--green);transition:width .3s;}
.prog-fill.blue{background:#378ADD;}
.form-row{display:grid;gap:8px;margin-bottom:10px;}
.form-row.cols2{grid-template-columns:1fr 1fr;}
.form-row.cols3{grid-template-columns:1fr 1fr 1fr;}
.form-row.cols4{grid-template-columns:1fr 1fr 1fr auto;}
input,select,textarea{padding:9px 12px;border-radius:8px;border:1px solid var(--border);font-size:14px;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);width:100%;outline:none;}
input:focus,select:focus,textarea:focus{border-color:var(--green);}
textarea{resize:vertical;min-height:80px;}
.btn{padding:9px 16px;border-radius:8px;border:1px solid var(--border);background:var(--card);color:var(--text);font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;}
.btn:hover{background:var(--bg);}
.btn-green{background:var(--green-dark);color:#fff;border-color:var(--green-dark);}
.btn-green:hover{background:var(--green);border-color:var(--green);}
.btn-sm{padding:6px 12px;font-size:13px;}
.del-btn{background:none;border:none;cursor:pointer;color:var(--muted);font-size:18px;line-height:1;padding:0 4px;}
.del-btn:hover{color:#E24B4A;}
.post-card{border-radius:var(--radius);padding:1rem 1.25rem;margin-bottom:10px;border:1px solid var(--border);background:var(--card);}
.post-card.quote{background:var(--gold-light);border-color:var(--gold);border-left:3px solid var(--gold);border-radius:0 var(--radius) var(--radius) 0;}
.post-card.pinned{border-left:3px solid var(--purple);border-radius:0 var(--radius) var(--radius) 0;}
.quote-text{font-family:'DM Serif Display',serif;font-size:17px;color:var(--gold-dark);line-height:1.5;margin-bottom:6px;font-style:italic;}
.quote-author{font-size:12px;color:var(--gold);font-weight:500;}
.post-body{font-size:14px;line-height:1.6;margin-bottom:6px;}
.post-meta{font-size:11px;color:var(--muted);}
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:20px;font-weight:600;margin-left:6px;vertical-align:middle;}
.badge-pin{background:var(--purple-light);color:var(--purple);}
.badge-goal{background:var(--gold-light);color:var(--gold-dark);}
.badge-achieved{background:var(--green-light);color:var(--green-dark);}
.goal-card{border-radius:var(--radius);border:1px solid var(--border);padding:1.25rem;margin-bottom:10px;background:var(--card);}
.goal-card.achieved{border-color:var(--green);background:var(--green-light);}
.sales-table{width:100%;font-size:13px;border-collapse:collapse;}
.sales-table th{text-align:left;font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;padding:6px 8px;border-bottom:1px solid var(--border);}
.sales-table td{padding:10px 8px;border-bottom:1px solid var(--border);}
.sales-table tr:last-child td{border-bottom:none;}
.type-toggle{display:flex;gap:6px;margin-bottom:12px;}
.type-btn{padding:5px 14px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;}
.type-btn.active{background:var(--green-light);color:var(--green-dark);border-color:var(--green);}
.type-btn.quote-t.active{background:var(--gold-light);color:var(--gold-dark);border-color:var(--gold);}
@media(max-width:480px){.form-row.cols3,.form-row.cols4{grid-template-columns:1fr 1fr;}.owner-hero{flex-direction:column;gap:8px;text-align:center;}.metric-3{grid-template-columns:1fr 1fr;}}
</style>
</head>
<body>
<div id="login-screen">
<div class="login-card">
<div class="login-logo">Heartland Permanent Lighting</div>
<div class="login-sub">Sign in to your dashboard</div>
<div class="field"><label>Username</label><input type="text" id="l-user" placeholder="Enter username" autocomplete="username"></div>
<div class="field"><label>Password</label><input type="password" id="l-pass" placeholder="Enter password" autocomplete="current-password"></div>
<button class="login-btn" onclick="doLogin()">Sign in</button>
<div class="login-err hidden" id="l-err">Invalid username or password</div>
</div>
</div>
<div id="app">
<div class="topbar">
<div class="topbar-logo">Heartland</div>
<div style="display:flex;align-items:center;gap:12px;">
<span class="topbar-user" id="topbar-name"></span>
<button class="logout-btn" onclick="doLogout()">Sign out</button>
</div>
</div>
<div class="tabs-wrap" id="tabs-wrap"></div>
<div class="content" id="content"></div>
</div>
<script>
let currentUser=null;
async function api(method,path,body){const res=await fetch(path,{method,headers:{'Content-Type':'application/json'},body:body?JSON.stringify(body):undefined,credentials:'include'});return res.json();}
async function doLogin(){const username=document.getElementById('l-user').value.trim();const password=document.getElementById('l-pass').value.trim();const err=document.getElementById('l-err');err.classList.add('hidden');const res=await api('POST','/api/login',{username,password});if(res.error){err.classList.remove('hidden');return;}currentUser=res;showApp();}
async function doLogout(){await api('POST','/api/logout');currentUser=null;document.getElementById('app').style.display='none';document.getElementById('login-screen').style.display='flex';}
document.getElementById('l-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin();});
function fmt(n){return'$'+Math.round(n).toLocaleString();}
function pct(a,b){return b>0?Math.min(100,Math.round((a/b)*100)):0;}
function ini(name){return name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();}
function showApp(){document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='block';document.getElementById('topbar-name').textContent=currentUser.name;if(currentUser.role==='owner')renderOwnerApp();else if(currentUser.role==='secretary')renderSecretaryApp();else renderEmployeeApp();}
function setupTabs(tabs,def){const wrap=document.getElementById('tabs-wrap');const content=document.getElementById('content');wrap.innerHTML=tabs.map(t=>`<button class="tab-btn ${t.id===def?'active':''}" onclick="switchTab('${t.id}',this)">${t.label}</button>`).join('');content.innerHTML=tabs.map(t=>`<div class="view ${t.id===def?'active':''}" id="${t.id}"></div>`).join('');}
function switchTab(id,btn){document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));btn.classList.add('active');document.getElementById(id).classList.add('active');}
function postHTML(p,canDelete){if(p.type==='quote'){return`<div class="post-card quote"><div class="quote-text">"${p.body}"</div><div class="quote-author">— ${p.author}</div><div style="display:flex;justify-content:space-between;margin-top:8px;"><div style="font-size:11px;color:var(--gold);">Weekly quote · ${p.date}</div>${canDelete?`<button class="del-btn" onclick="deletePost(${p.id})">×</button>`:''}</div></div>`;}return`<div class="post-card ${p.pin?'pinned':''}"><div style="display:flex;justify-content:space-between;margin-bottom:6px;"><div style="font-size:12px;font-weight:500;">To: ${p.target}${p.pin?'<span class="badge badge-pin">Pinned</span>':''}</div>${canDelete?`<button class="del-btn" onclick="deletePost(${p.id})">×</button>`:''}</div><div class="post-body">${p.body}</div><div class="post-meta">${p.date}</div></div>`;}
async function renderEmployeeApp(){const data=await api('GET','/api/my-stats');setupTabs([{id:'my-dash',label:'My dashboard'},{id:'board',label:'Team board'}],'my-dash');const goal=data.goal;const p=goal?pct(data.revenue,goal.target):0;const achieved=goal&&data.revenue>=goal.target;document.getElementById('my-dash').innerHTML=`<div class="earned-hero"><div class="earned-label">Your total earned</div><div class="earned-amount">${fmt(data.earned)}</div><div class="earned-sub">${data.installs} install${data.installs!==1?'s':''} · ${data.rate}% commission rate</div></div><div class="metrics"><div class="metric"><div class="metric-label">Revenue generated</div><div class="metric-value">${fmt(data.revenue)}</div></div><div class="metric"><div class="metric-label">Installs completed</div><div class="metric-value">${data.installs}</div></div></div>${goal?`<div class="goal-card ${achieved?'achieved':''}"><div class="section-label">Your goal</div><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;"><div><div style="font-size:15px;font-weight:500;">${goal.prize}</div><div style="font-size:12px;color:var(--muted);margin-top:2px;">${achieved?'You did it!':'Keep going — you\'re '+p+'% there'}</div></div><span class="badge ${achieved?'badge-achieved':'badge-goal'}">${achieved?'Achieved':p+'%'}</span></div><div class="prog-track"><div class="prog-fill ${achieved?'':'blue'}" style="width:${p}%"></div></div><div style="display:flex;justify-content:space-between;margin-top:6px;font-size:12px;color:var(--muted);"><span>Current: ${fmt(data.revenue)}</span><span>${achieved?'Goal unlocked!':'Need '+fmt(Math.max(0,goal.target-data.revenue))+' more'}</span><span>Target: ${fmt(goal.target)}</span></div></div>`:''} ${data.sales.length>0?`<div class="card"><div class="section-label">Recent sales</div><table class="sales-table"><tr><th>Date</th><th>Address</th><th>Amount</th><th>Earned</th></tr>${data.sales.map(s=>`<tr><td>${s.date}</td><td>${s.address||'—'}</td><td>${fmt(s.amount)}</td><td style="color:var(--green-dark);font-weight:500;">${fmt(s.amount*data.rate/100)}</td></tr>`).join('')}</table></div>`:''}`;
document.getElementById('board').innerHTML=data.posts.length===0?'<div class="card" style="color:var(--muted);font-size:14px;">No posts yet.</div>':data.posts.map(p=>postHTML(p,false)).join('');}
async function renderOwnerApp(){setupTabs([{id:'overview',label:'Overview'},{id:'team',label:'Team'},{id:'goals',label:'Goals'},{id:'board-owner',label:'Team board'},{id:'log-sale',label:'Log sale'},{id:'manage',label:'Manage'}],'overview');await refreshOwner();}
async function refreshOwner(){const[empData,goals,posts]=await Promise.all([api('GET','/api/employees'),api('GET','/api/goals'),api('GET','/api/posts')]);renderOverview(empData,goals);renderTeam(empData,goals);renderGoals(empData,goals);renderBoard(posts);renderLogSale(empData);renderManage(empData);}
function renderOverview(empData,goals){const{employees,ownerSales}=empData;const totalRev=employees.reduce((s,e)=>s+e.revenue,0)+ownerSales.revenue;const totalComm=employees.reduce((s,e)=>s+e.earned,0);const totalInst=employees.reduce((s,e)=>s+e.installs,0)+ownerSales.installs;const ownerEarnings=ownerSales.revenue+employees.reduce((s,e)=>s+(e.revenue-e.earned),0);document.getElementById('overview').innerHTML=`<div class="owner-hero"><div><div style="font-size:13px;color:var(--green);font-weight:500;">Your total earnings</div><div style="font-size:12px;color:var(--green);margin-top:2px;">your sales + share after paying commissions</div></div><div class="owner-hero-amount">${fmt(ownerEarnings)}</div></div><div class="metrics metric-3"><div class="metric"><div class="metric-label">Total revenue</div><div class="metric-value">${fmt(totalRev)}</div></div><div class="metric"><div class="metric-label">Paid in commissions</div><div class="metric-value">${fmt(totalComm)}</div></div><div class="metric"><div class="metric-label">Total installs</div><div class="metric-value">${totalInst}</div></div></div><div class="card"><div class="section-label">Breakdown</div>${[...employees].sort((a,b)=>b.revenue-a.revenue).map(e=>`<div class="emp-item"><div class="avatar" style="width:36px;height:36px;font-size:11px;background:${e.color};color:${e.tc}">${ini(e.name)}</div><div style="flex:1;"><div class="emp-name">${e.name}</div><div class="emp-sub">${e.installs} installs · ${e.rate}%</div></div><div style="text-align:right;"><div class="emp-earned-amount">${fmt(e.earned)}</div><div class="emp-earned-rev">${fmt(e.revenue)} rev · ${fmt(e.revenue-e.earned)} your share</div></div></div>`).join('')}${ownerSales.revenue>0?`<div class="emp-item" style="background:rgba(234,243,222,0.4);border-radius:8px;padding:12px 8px;"><div class="avatar" style="width:36px;height:36px;font-size:11px;background:#EAF3DE;color:#27500A">ME</div><div style="flex:1;"><div class="emp-name" style="color:var(--green-dark)">You (owner)</div><div class="emp-sub">${ownerSales.installs} installs · 100%</div></div><div style="text-align:right;"><div class="emp-earned-amount">${fmt(ownerSales.revenue)}</div><div class="emp-earned-rev">100% kept</div></div></div>`:''}</div>`;}
function renderTeam(empData,goals){document.getElementById('team').innerHTML=[...empData.employees].sort((a,b)=>b.revenue-a.revenue).map((e,i)=>{const goal=goals.find(g=>g.userId===e.id);const p=goal?pct(e.revenue,goal.target):0;const achieved=goal&&e.revenue>=goal.target;return`<div class="card"><div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:var(--muted);width:20px;">#${i+1}</div><div class="avatar" style="width:40px;height:40px;font-size:12px;background:${e.color};color:${e.tc}">${ini(e.name)}</div><div style="flex:1;"><div style="font-size:15px;font-weight:500;">${e.name}</div><div style="font-size:12px;color:var(--muted);">${e.installs} installs · ${e.rate}% rate</div></div></div><div style="background:var(--green-light);border-radius:10px;padding:1rem;text-align:center;margin-bottom:10px;"><div style="font-size:12px;color:var(--green);font-weight:500;margin-bottom:4px;">Total earned</div><div style="font-family:'DM Serif Display',serif;font-size:36px;color:var(--green-dark);">${fmt(e.earned)}</div><div style="font-size:12px;color:var(--green);margin-top:4px;">from ${fmt(e.revenue)} in revenue</div></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;"><div class="metric"><div class="metric-label">Your share</div><div class="metric-value" style="font-size:18px;">${fmt(e.revenue-e.earned)}</div></div><div class="metric"><div class="metric-label">Installs</div><div class="metric-value" style="font-size:18px;">${e.installs}</div></div></div>${goal?`<div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><div style="font-size:13px;font-weight:500;">Goal: ${goal.prize}</div><span class="badge ${achieved?'badge-achieved':'badge-goal'}">${achieved?'Achieved!':p+'%'}</span></div><div class="prog-track"><div class="prog-fill ${achieved?'':'blue'}" style="width:${p}%"></div></div><div style="font-size:11px;color:var(--muted);margin-top:4px;">${achieved?'Goal unlocked!':'Needs '+fmt(Math.max(0,goal.target-e.revenue))+' more'}</div></div>`:''}</div>`;}).join('');}
function renderGoals(empData,goals){const empOptions=empData.employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('');document.getElementById('goals').innerHTML=`<div class="card"><div class="section-label">Set a goal</div><div class="form-row cols4"><select id="g-emp">${empOptions}</select><input type="number" id="g-target" placeholder="Target $"><input type="text" id="g-prize" placeholder="Prize (e.g. $500 cash)"><button class="btn btn-green" onclick="addGoal()">+ Set</button></div></div>${goals.length===0?'<div style="font-size:14px;color:var(--muted);padding:.5rem 0;">No goals set yet.</div>':goals.map(g=>{const e=empData.employees.find(x=>x.id===g.userId);if(!e)return'';const p=pct(e.revenue,g.target);const achieved=e.revenue>=g.target;return`<div class="goal-card ${achieved?'achieved':''}"><div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;"><div class="avatar" style="width:32px;height:32px;font-size:11px;background:${e.color};color:${e.tc}">${ini(e.name)}</div><div style="flex:1;"><div style="font-size:14px;font-weight:500;">${e.name}</div><span class="badge ${achieved?'badge-achieved':'badge-goal'}">${achieved?'Achieved: ':'Prize: '}${g.prize}</span></div><div style="text-align:right;font-size:13px;font-weight:500;">${fmt(e.revenue)} / ${fmt(g.target)}</div><button class="del-btn" onclick="deleteGoal(${g.id})">×</button></div><div class="prog-track" style="height:10px;"><div class="prog-fill ${achieved?'':'blue'}" style="width:${p}%"></div></div><div style="display:flex;justify-content:space-between;margin-top:6px;font-size:11px;color:var(--muted);"><span>Current: ${fmt(e.revenue)}</span><span style="color:${achieved?'var(--green)':'var(--muted)'};">${achieved?'Unlocked!':'Need '+fmt(Math.max(0,g.target-e.revenue))+' more'}</span><span>Target: ${fmt(g.target)}</span></div></div>`;}).join('')}`;}
function renderBoard(posts){const el=document.getElementById('board-owner');if(!el)return;el.innerHTML=`<div class="card"><div class="section-label">Post to team</div><div class="type-toggle"><button class="type-btn active" id="tb-msg" onclick="setBoardType('msg')">Message</button><button class="type-btn quote-t" id="tb-quote" onclick="setBoardType('quote')">Weekly quote</button></div><div id="compose-msg"><textarea id="p-body" placeholder="Write a message to your team..."></textarea><div class="form-row cols3" style="margin-top:8px;"><input type="text" id="p-target" placeholder="To: All team"><label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--muted);cursor:pointer;"><input type="checkbox" id="p-pin" style="width:auto;"> Pin to top</label><button class="btn btn-green" onclick="postMessage()">Post</button></div></div><div id="compose-quote" class="hidden"><textarea id="q-body" placeholder="Paste your motivational quote here..."></textarea><div class="form-row cols3" style="margin-top:8px;"><input type="text" id="q-author" placeholder="— Author name"><div></div><button class="btn btn-green" onclick="postQuote()">Post quote</button></div></div></div><div id="posts-list">${posts.length===0?'<div style="font-size:14px;color:var(--muted);">No posts yet.</div>':[...posts].sort((a,b)=>(b.pin?1:0)-(a.pin?1:0)).map(p=>postHTML(p,true)).join('')}</div>`;}
function renderLogSale(empData){const empOptions=empData.employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('');document.getElementById('log-sale').innerHTML=`<div class="card"><div class="section-label">Log a new sale</div><div class="form-row cols2"><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Employee</label><select id="s-emp">${empOptions}</select></div><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Sale amount $</label><input type="number" id="s-amount" placeholder="e.g. 1400"></div></div><div class="form-row cols2"><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Address</label><input type="text" id="s-address" placeholder="123 Main St"></div><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Date</label><input type="date" id="s-date" value="${new Date().toISOString().split('T')[0]}"></div></div><button class="btn btn-green" onclick="logSale()">Log sale</button><div id="s-confirm" class="hidden" style="font-size:13px;color:var(--green);margin-top:8px;font-weight:500;">Sale logged!</div></div><div class="card"><div class="section-label">Your own sales</div><div class="form-row cols2"><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Your revenue $</label><input type="number" id="o-rev" placeholder="0" value="${empData.ownerSales.revenue}"></div><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Your installs</label><input type="number" id="o-inst" placeholder="0" value="${empData.ownerSales.installs}"></div></div><button class="btn btn-green" onclick="saveOwnerSales()">Save</button></div>`;}
function renderManage(empData){document.getElementById('manage').innerHTML=`<div class="card"><div class="section-label">Add employee</div><div class="form-row cols2"><input type="text" id="m-name" placeholder="Full name"><input type="text" id="m-user" placeholder="Username"></div><div class="form-row cols2"><input type="password" id="m-pass" placeholder="Password"><input type="number" id="m-rate" placeholder="Commission % (e.g. 40)"></div><button class="btn btn-green" onclick="addEmployee()">+ Add employee</button><div id="m-confirm" class="hidden" style="font-size:13px;color:var(--green);margin-top:8px;font-weight:500;">Employee added!</div></div><div class="card"><div class="section-label">Update rates & passwords</div>${empData.employees.map(e=>`<div style="display:grid;grid-template-columns:1fr 90px 90px 90px;gap:8px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);"><div style="font-size:14px;">${e.name}</div><div style="display:flex;align-items:center;gap:4px;"><input type="number" value="${e.rate}" id="rate-${e.id}" style="width:55px;text-align:center;" min="1" max="100"><span style="font-size:12px;color:var(--muted);">%</span></div><button class="btn btn-sm" onclick="updateRate(${e.id})">Save rate</button><div style="display:flex;gap:4px;"><input type="password" placeholder="New pw" id="pw-${e.id}" style="width:80px;"><button class="btn btn-sm" onclick="updatePassword(${e.id})">Set</button></div></div>`).join('')}</div>`;}
async function renderSecretaryApp(){const empData=await api('GET','/api/employees');setupTabs([{id:'sec-sales',label:'Log sale'},{id:'sec-team',label:'Team'}],'sec-sales');const empOptions=empData.employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('');document.getElementById('sec-sales').innerHTML=`<div class="card"><div class="section-label">Log a new sale</div><div class="form-row cols2"><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Employee</label><select id="ss-emp">${empOptions}</select></div><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Sale amount $</label><input type="number" id="ss-amount" placeholder="e.g. 1400"></div></div><div class="form-row cols2"><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Address</label><input type="text" id="ss-address" placeholder="123 Main St"></div><div><label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Date</label><input type="date" id="ss-date" value="${new Date().toISOString().split('T')[0]}"></div></div><button class="btn btn-green" onclick="logSaleSecretary()">Log sale</button><div id="ss-confirm" class="hidden" style="font-size:13px;color:var(--green);margin-top:8px;font-weight:500;">Sale logged!</div></div>`;document.getElementById('sec-team').innerHTML=`<div class="card"><div class="section-label">Team overview</div>${[...empData.employees].sort((a,b)=>b.revenue-a.revenue).map((e,i)=>`<div class="emp-item"><div style="font-size:12px;color:var(--muted);width:20px;">#${i+1}</div><div class="avatar" style="width:36px;height:36px;font-size:11px;background:${e.color};color:${e.tc}">${ini(e.name)}</div><div style="flex:1;"><div class="emp-name">${e.name}</div><div class="emp-sub">${e.installs} installs · ${e.rate}%</div></div><div style="text-align:right;"><div class="emp-earned-amount">${fmt(e.earned)}</div><div class="emp-earned-rev">${fmt(e.revenue)} rev</div></div></div>`).join('')}</div>`;}
function setBoardType(t){document.getElementById('compose-msg').classList.toggle('hidden',t!=='msg');document.getElementById('compose-quote').classList.toggle('hidden',t!=='quote');document.getElementById('tb-msg').classList.toggle('active',t==='msg');document.getElementById('tb-quote').classList.toggle('active',t==='quote');}
async function postMessage(){const body=document.getElementById('p-body').value.trim();const target=document.getElementById('p-target').value.trim()||'All team';const pin=document.getElementById('p-pin').checked;if(!body)return;await api('POST','/api/posts',{type:'message',body,target,pin});document.getElementById('p-body').value='';document.getElementById('p-target').value='';document.getElementById('p-pin').checked=false;renderBoard(await api('GET','/api/posts'));}
async function postQuote(){const body=document.getElementById('q-body').value.trim();const author=document.getElementById('q-author').value.trim()||'Unknown';if(!body)return;await api('POST','/api/posts',{type:'quote',body,author});document.getElementById('q-body').value='';document.getElementById('q-author').value='';renderBoard(await api('GET','/api/posts'));}
async function deletePost(id){await api('DELETE',`/api/posts/${id}`);renderBoard(await api('GET','/api/posts'));}
async function addGoal(){const userId=document.getElementById('g-emp').value;const target=document.getElementById('g-target').value;const prize=document.getElementById('g-prize').value.trim();if(!target||!prize)return;await api('POST','/api/goals',{userId,target,prize});document.getElementById('g-target').value='';document.getElementById('g-prize').value='';await refreshOwner();}
async function deleteGoal(id){await api('DELETE',`/api/goals/${id}`);await refreshOwner();}
async function logSale(){const userId=document.getElementById('s-emp').value;const amount=document.getElementById('s-amount').value;const address=document.getElementById('s-address').value;const date=document.getElementById('s-date').value;if(!amount)return;await api('POST','/api/sales',{userId,amount,address,date});document.getElementById('s-amount').value='';document.getElementById('s-address').value='';const c=document.getElementById('s-confirm');c.classList.remove('hidden');setTimeout(()=>c.classList.add('hidden'),3000);await refreshOwner();}
async function logSaleSecretary(){const userId=document.getElementById('ss-emp').value;const amount=document.getElementById('ss-amount').value;const address=document.getElementById('ss-address').value;const date=document.getElementById('ss-date').value;if(!amount)return;await api('POST','/api/sales',{userId,amount,address,date});document.getElementById('ss-amount').value='';document.getElementById('ss-address').value='';const c=document.getElementById('ss-confirm');c.classList.remove('hidden');setTimeout(()=>c.classList.add('hidden'),3000);}
async function saveOwnerSales(){await api('POST','/api/owner-sales',{revenue:document.getElementById('o-rev').value,installs:document.getElementById('o-inst').value});await refreshOwner();}
async function addEmployee(){const name=document.getElementById('m-name').value.trim();const username=document.getElementById('m-user').value.trim();const password=document.getElementById('m-pass').value.trim();const rate=document.getElementById('m-rate').value;if(!name||!username||!password)return;await api('POST','/api/employees',{name,username,password,rate});document.getElementById('m-name').value='';document.getElementById('m-user').value='';document.getElementById('m-pass').value='';document.getElementById('m-rate').value='';const c=document.getElementById('m-confirm');c.classList.remove('hidden');setTimeout(()=>c.classList.add('hidden'),3000);await refreshOwner();}
async function updateRate(id){await api('PATCH',`/api/employees/${id}`,{rate:document.getElementById(`rate-${id}`).value});await refreshOwner();}
async function updatePassword(id){const pw=document.getElementById(`pw-${id}`).value;if(!pw)return;await api('PATCH',`/api/employees/${id}`,{password:pw});document.getElementById(`pw-${id}`).value='';alert('Password updated!');}
(async()=>{try{const me=await api('GET','/api/me');if(me&&me.role){currentUser=me;showApp();}}catch{}})();
</script>
</body>
</html>
